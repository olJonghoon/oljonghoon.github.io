# --- Parameters --------------------------------------------------------------
Wtot  <- 100         # total wealth (absolute scale)
n     <- 8           # baseline inequality parameter
g     <- 0.1       # growth rate (decimal)
np    <- 8          # post-shock inequality parameter n' = n + delta
delta <- np - n
r     <- 0.20        # proportional tax rate for universal rebate (adjustable)
# --- Functions (levels by rank x in [0,1]) -----------------------------------
w_sq <- function(x)  Wtot * n  * x^(n  - 1)
w_rd <- function(x)  (1 - r) * w_sq(x) + r * Wtot
w_gr <- function(x)  (1 + g) * Wtot * np * x^(np - 1)
# --- Closed-form thresholds ---------------------------------------------------
x_R <- n^(-1/(n-1))                              # SQ vs. Redistribution (mean cutoff)
x_G <- NA_real_                                   # SQ vs. Growth (only if delta != 0)
if (abs(delta) > 1e-12) {
base <- n / ((1 + g) * np)
if (base > 0) x_G <- base^(1/delta)
}
# clamp to [0,1]
clamp01 <- function(z) max(0, min(1, z))
if (is.finite(x_G)) x_G <- clamp01(x_G) else x_G <- NA_real_
# --- Redistribution vs Growth crossing (numeric) ------------------------------
f_RG <- function(x) w_rd(x) - w_gr(x)
x_RG <- NA_real_
# scan for sign change then refine with uniroot
xs <- seq(0, 1, length.out = 801)
fa <- f_RG(xs[-length(xs)])
fb <- f_RG(xs[-1])
flip <- which(is.finite(fa) & is.finite(fb) & fa * fb < 0)
if (length(flip) >= 1) {
k  <- flip[1]
lo <- max(1e-8, xs[k]); hi <- min(1 - 1e-8, xs[k+1])
f1 <- f_RG(lo); f2 <- f_RG(hi)
if (is.finite(f1) && is.finite(f2) && f1 * f2 < 0) {
x_RG <- uniroot(f_RG, lower = lo, upper = hi, tol = 1e-12, maxiter = 1000)$root
}
}
if (is.finite(x_RG)) x_RG <- clamp01(x_RG) else x_RG <- NA_real_
# --- Data for plotting --------------------------------------------------------
library(ggplot2)
grid <- data.frame(x = seq(0, 1, length.out = 2000))
grid$SQ <- w_sq(grid$x)
grid$RD <- w_rd(grid$x)
grid$GR <- w_gr(grid$x)
# Long format for ggplot
long <- reshape(
grid,
direction = "long",
varying  = list(c("SQ","RD","GR")),
v.names  = "income",
times    = c("Status Quo","Redistribution","Growth"),
timevar  = "policy",
idvar    = "x"
)
long$policy <- factor(long$policy, levels = c("Status Quo","Redistribution","Growth"))
# --- replace your line layer (use linewidth instead of size) ---
p <- ggplot(long, aes(x = x, y = income, color = policy)) +
geom_line(linewidth = 1.1) +   # <- changed
scale_color_manual(values = c(
"Status Quo"     = "#1f77b4",
"Redistribution" = "#2ca02c",
"Growth"         = "#d62728"
)) +
labs(
title = "",
x = "Population rank",
y = "Income",
color = "Policy"
) +
theme_minimal(base_size = 13) +
theme(legend.position = "top")
# --- compute a safe top y for label placement ---
ymax <- max(long$income, na.rm = TRUE)
# --- helper that draws a vline + parsed label using geom_label() ---
add_vline_label <- function(p, x, label_chr, parse = FALSE) {
if (!is.finite(x) || x <= 0 || x >= 1) return(p)
p <- p + geom_vline(xintercept = x, linetype = "dashed",
linewidth = 0.6, color = "grey40")
p <- p + geom_label(
data = data.frame(x = x, y = ymax, lab = label_chr),
aes(x = x, y = y, label = lab),
vjust = 1.3, size = 3.5, label.size = 0.2, fill = "white",
parse = parse, inherit.aes = FALSE
)
p
}
# --- add the three markers (x_R, x_G use parsed math; x_RG as pla
p <- add_vline_label(p, x_RG, "x_RG", parse = FALSE)
p <- p +
coord_cartesian(xlim = c(0.5, 0.9), clip = "off") +
scale_x_continuous(
limits = c(0.5, 0.90),            # keeps consistent ticks
breaks  = seq(0.60, 0.9, by = 0.1),
labels  = scales::number_format(accuracy = 0.01)
)+
scale_y_continuous(
limits = c(0, 300),
breaks = seq(0, 300, by = 100)
)
# render / save
print(p)
ggsave("theory_scenario.png", p, width = 8, height = 5.2, dpi = 300)
ggsave("theory_scenario.pdf", p, width = 8, height = 5.2)
